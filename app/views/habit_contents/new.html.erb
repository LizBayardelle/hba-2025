<div class="flex h-screen relative" style="background-color: var(--bg);">
  <%= render 'shared/sidebar' %>
  <main class="flex-1 overflow-y-auto md:ml-[224px]">
    <div class="p-8">
      <div class="max-w-3xl mx-auto">
        <!-- Header -->
        <div class="mb-8">
          <h1 class="text-3xl font-bold mb-2" style="color: var(--ink);">
            Add Content to <%= @habit.name %>
          </h1>
          <p class="text-sm font-light" style="color: #657b84;">
            Attach a document, video, or resource to this habit
          </p>
        </div>

        <!-- Form Card -->
        <div class="v2-card p-8">
          <%= form_with model: [@habit, @habit_content], local: true do |f| %>
            <!-- Error Messages -->
            <% if @habit_content.errors.any? %>
              <div class="mb-6 p-4 rounded-lg border-2" style="background-color: #FFE4E6; border-color: #FB7185;">
                <h3 class="font-semibold mb-2" style="color: #BE123C;">
                  <%= pluralize(@habit_content.errors.count, "error") %> prohibited this content from being saved:
                </h3>
                <ul class="list-disc list-inside text-sm" style="color: #BE123C;">
                  <% @habit_content.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <!-- Content Type -->
            <div class="mb-6">
              <%= f.label :content_type, "Content Type", class: "block text-sm font-semibold mb-3", style: "color: var(--ink);" %>
              <div class="grid grid-cols-2 gap-3" x-data="{ type: 'youtube' }">
                <% HabitContent::CONTENT_TYPES.each do |type| %>
                  <label class="cursor-pointer">
                    <%= f.radio_button :content_type, type, class: "hidden",
                        'x-on:change': "type = '#{type}'",
                        checked: type == 'youtube' %>
                    <div class="p-4 rounded-lg border-2 transition hover:shadow-md"
                         :class="type === '<%= type %>' ? 'border-[#6B8A99] bg-[#E8EEF1]' : 'border-gray-200'"
                         style="cursor: pointer;">
                      <div class="flex items-center gap-2">
                        <i class="fa-solid <%= case type
                          when 'document' then 'fa-file-alt'
                          when 'youtube' then 'fa-brands fa-youtube'
                          when 'video' then 'fa-video'
                          when 'link' then 'fa-link'
                          end %> text-lg" :style="type === '<%= type %>' ? 'color: var(--ink);' : 'color: #9CA3A8;'"></i>
                        <span class="font-semibold capitalize" :style="type === '<%= type %>' ? 'color: var(--ink);' : 'color: #657b84;'">
                          <%= type %>
                        </span>
                      </div>
                    </div>
                  </label>
                <% end %>
              </div>
            </div>

            <!-- Title -->
            <div class="mb-6">
              <%= f.label :title, class: "block text-sm font-semibold mb-2", style: "color: var(--ink);" %>
              <%= f.text_field :title,
                  class: "w-full px-4 py-3 rounded-lg border-2 focus:outline-none transition font-light",
                  style: "border-color: #E8EEF1;",
                  placeholder: "e.g., Morning Prayer, Spanish Lesson 1" %>
            </div>

            <!-- URL Field (for youtube, video, link) -->
            <div class="mb-6" x-show="['youtube', 'video', 'link'].includes(type)">
              <%= label_tag 'habit_content[metadata][url]', "URL", class: "block text-sm font-semibold mb-2", style: "color: var(--ink);" %>
              <%= text_field_tag 'habit_content[metadata][url]', '',
                  class: "w-full px-4 py-3 rounded-lg border-2 focus:outline-none transition font-light",
                  style: "border-color: #E8EEF1;",
                  placeholder: "https://www.youtube.com/watch?v=..." %>
              <p class="text-xs font-light mt-2" style="color: #657b84;">
                Paste the full YouTube URL - we'll handle the rest!
              </p>
            </div>

            <!-- Document Body (for document type) -->
            <div class="mb-6" x-show="type === 'document'">
              <%= f.label :body, "Document Content", class: "block text-sm font-semibold mb-2", style: "color: var(--ink);" %>
              <%= f.rich_text_area :body,
                  class: "w-full rounded-lg border-2",
                  style: "border-color: #E8EEF1;" %>
            </div>

            <!-- Actions -->
            <div class="flex gap-3">
              <%= f.submit "Add Content",
                  class: "v2-btn v2-btn-primary cursor-pointer" %>
              <%= link_to "Cancel", category_path(@habit.category),
                  class: "v2-btn v2-btn-secondary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </main>
</div>
