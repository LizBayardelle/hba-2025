<% content_for :head do %>
  <%= javascript_include_tag "lists_app", type: "module" %>
<% end %>

<div class="flex h-screen relative" style="background-color: var(--bg);">
  <%= render 'shared/sidebar' %>

  <main class="flex-1 overflow-y-auto md:ml-[224px]">
    <div id="lists-react-root" style="background-color: var(--bg); min-height: 100%;" data-default-grouping="<%= current_user.default_lists_grouping %>"></div>
  </main>
</div>
