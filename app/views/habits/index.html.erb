<div class="flex h-screen relative" style="background-color: var(--bg);">
  <%= render 'shared/sidebar' %>

  <!-- Main Content Area -->
  <main class="flex-1 overflow-y-auto md:ml-[224px]">
    <div id="habits-root" style="background-color: var(--bg); min-height: 100%;" data-default-grouping="<%= current_user.default_habits_grouping %>" data-tracking-paused="<%= current_user.tracking_paused %>"></div>
  </main>
</div>

<%= javascript_include_tag "habits_app", type: "module", "data-turbo-track": "reload", defer: true %>
