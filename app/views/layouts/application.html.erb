<!DOCTYPE html>
<html data-theme="<%= user_signed_in? ? (current_user.theme || 'cream') : 'cream' %>">
  <head>
    <title><%= content_for(:title) || "Habit Beaver" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="HabitBeaver" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Inline+Display:wght@100;200;300;400;500;600;700;800;900&family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Figtree:wght@300;400;500;600;700&family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=IBM+Plex+Mono:wght@300;400&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <!-- Trix Editor -->
    <link rel="stylesheet" type="text/css" href="https://unpkg.com/trix@2.0.8/dist/trix.css">

    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <style>
      [x-cloak] { display: none !important; }

      /* Trix Editor Styling */
      trix-toolbar .trix-button-group {
        border-color: #E8EEF1;
        background: white;
      }

      trix-toolbar .trix-button {
        border-bottom-color: #E8EEF1;
      }

      trix-toolbar .trix-button.trix-active {
        background: #E8EEF1;
      }

      /* Make heading button a dropdown */
      trix-toolbar .trix-button--icon-heading-1 {
        position: relative;
      }

      trix-toolbar .trix-button-group--block-tools {
        position: static;
      }

      trix-toolbar {
        position: relative;
        z-index: 100;
      }

      /* Let toolbar buttons wrap instead of causing x-scroll */
      trix-toolbar .trix-button-row {
        flex-wrap: wrap !important;
        overflow-x: hidden !important;
        gap: 2px;
      }

      .trix-heading-dropdown {
        position: static !important;
      }

      .trix-heading-menu {
        position: fixed !important;
        z-index: 10000 !important;
      }

      trix-editor {
        border: 1px solid var(--border);
        border-radius: 0.5rem;
        padding: 1rem;
        height: 300px;
        max-height: 300px;
        overflow-y: auto;
        position: relative;
        z-index: 1;
        background: var(--surface);
        color: var(--ink);
        font-family: var(--font-body);
      }

      trix-editor:focus {
        outline: none;
        border-color: var(--border-hover);
      }

      /* v2 headings inside trix editor */
      trix-editor h1 {
        font-family: var(--font-display);
        font-size: 1.75em;
        font-weight: 400;
        letter-spacing: -0.02em;
        margin: 0.5em 0;
        color: var(--ink);
      }
      trix-editor h2 {
        font-family: var(--font-body);
        font-size: 1.3em;
        font-weight: 600;
        letter-spacing: -0.01em;
        margin: 0.5em 0;
        color: var(--ink);
      }
      trix-editor h3 {
        font-family: var(--font-body);
        font-size: 1.15em;
        font-weight: 600;
        margin: 0.5em 0;
        color: var(--ink);
      }
      trix-editor h4 {
        font-family: var(--font-body);
        font-size: 1em;
        font-weight: 600;
        margin: 0.5em 0;
        color: var(--ink-secondary);
      }
      trix-editor h5 {
        font-family: var(--font-body);
        font-size: 0.9em;
        font-weight: 600;
        margin: 0.5em 0;
        color: var(--ink-secondary);
      }
      trix-editor h6 {
        font-family: var(--font-body);
        font-size: 0.8em;
        font-weight: 600;
        letter-spacing: 0.03em;
        margin: 0.5em 0;
        color: var(--ink-tertiary);
      }
    </style>

    <%= stylesheet_link_tag "application" %>
    <%= javascript_include_tag "application", type: "module" %>
  </head>

  <body>
    <!-- Flash Messages -->
    <% if notice || alert %>
      <div class="fixed top-4 right-4 z-50 max-w-md" x-data="{ show: true }" x-show="show" x-transition x-init="setTimeout(() => show = false, 5000)">
        <% if notice %>
          <div class="mb-3 flex items-start gap-3 p-4 rounded-lg shadow-lg border-2" style="background-color: #D7EDCB; border-color: #7CB342;">
            <div class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center" style="background-color: #7CB342;">
              <i class="fa-solid fa-check text-white text-xs"></i>
            </div>
            <div class="flex-1">
              <p class="font-semibold text-sm mb-1" style="color: #4A6B27;">Success</p>
              <p class="text-sm font-light" style="color: #4A6B27;"><%= notice %></p>
            </div>
            <button @click="show = false" class="flex-shrink-0 text-sm hover:opacity-70 transition" style="color: #4A6B27;">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>
        <% end %>
        <% if alert %>
          <div class="mb-3 flex items-start gap-3 p-4 rounded-lg shadow-lg border-2" style="background-color: #FFE4E6; border-color: #FB7185;">
            <div class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center" style="background-color: #FB7185;">
              <i class="fa-solid fa-exclamation text-white text-xs"></i>
            </div>
            <div class="flex-1">
              <p class="font-semibold text-sm mb-1" style="color: #BE123C;">Error</p>
              <p class="text-sm font-light" style="color: #BE123C;"><%= alert %></p>
            </div>
            <button @click="show = false" class="flex-shrink-0 text-sm hover:opacity-70 transition" style="color: #BE123C;">
              <i class="fa-solid fa-xmark"></i>
            </button>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
