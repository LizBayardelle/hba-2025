<% if resource.errors.any? %>
  <div style="margin-bottom: 16px; padding: 12px 16px; border-radius: 8px; background: var(--overdue-bg); font-family: var(--font-body); font-size: 0.833rem; color: var(--overdue);">
    <% resource.errors.full_messages.each do |message| %>
      <div style="margin-bottom: 2px;"><%= message %></div>
    <% end %>
  </div>
<% end %>
