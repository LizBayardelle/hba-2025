<%= render 'shared/public_nav' %>

<div class="min-h-screen flex items-center justify-center px-4 py-12" style="background: var(--bg);">
  <div class="w-full max-w-sm">
    <!-- Logo -->
    <div class="text-center" style="margin-bottom: 32px;">
      <div style="width: 36px; height: 36px; background: var(--ink); border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 12px;">
        <svg width="18" height="18" viewBox="0 0 14 14" fill="none"><rect x="2" y="3" width="4" height="8" rx="1" fill="var(--bg)"/><rect x="8" y="3" width="4" height="5" rx="1" fill="var(--bg)" opacity="0.5"/></svg>
      </div>
      <h1 class="v2-h2" style="margin-bottom: 4px;">Welcome back</h1>
      <p class="v2-small" style="color: var(--ink-tertiary);">Sign in to your account</p>
    </div>

    <!-- Card -->
    <div class="v2-card" style="padding: 28px;">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div style="margin-bottom: 16px;">
          <%= f.label :email, "Email", style: "display: block; margin-bottom: 6px; font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com",
              style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
        </div>

        <div style="margin-bottom: 16px;">
          <%= f.label :password, "Password", style: "display: block; margin-bottom: 6px; font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);" %>
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "Enter your password",
              style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center" style="margin-bottom: 20px; font-family: var(--font-body); font-size: 0.833rem; color: var(--ink-secondary);">
            <%= f.check_box :remember_me, style: "accent-color: var(--ink); width: 15px; height: 15px; margin-right: 8px;" %>
            <%= f.label :remember_me, "Remember me" %>
          </div>
        <% end %>

        <%= f.submit "Sign In", class: "v2-btn v2-btn-primary", style: "width: 100%; padding: 10px; font-size: 0.9rem; justify-content: center;" %>
      <% end %>

      <div style="margin-top: 20px; padding-top: 16px; border-top: 1px solid var(--border); text-align: center;">
        <%= link_to "Forgot your password?", new_password_path(resource_name), style: "font-family: var(--font-body); font-size: 0.8rem; color: var(--ink-tertiary); text-decoration: none;" %>
      </div>
    </div>

    <div style="text-align: center; margin-top: 20px;">
      <span style="font-family: var(--font-body); font-size: 0.833rem; color: var(--ink-tertiary);">Don't have an account? </span>
      <%= link_to "Create one", new_registration_path(resource_name), style: "font-family: var(--font-body); font-size: 0.833rem; color: var(--ink); font-weight: 500; text-decoration: none;" %>
    </div>
  </div>
</div>
