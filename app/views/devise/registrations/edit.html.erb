<div class="flex h-screen relative" style="background-color: var(--bg);">
  <%= render 'shared/sidebar' %>

  <main class="flex-1 overflow-y-auto md:ml-[224px]">
    <!-- v2 Header -->
    <div class="sticky top-0 z-10" style="background: var(--bg);">
      <div class="pl-14 pr-4 pt-6 pb-4 md:pl-8 md:pr-8 md:pt-8 md:pb-5 max-w-2xl">
        <h1 class="v2-h1">Account</h1>
      </div>
      <div style="height: 12px; background: linear-gradient(to bottom, var(--bg), transparent); pointer-events: none;"></div>
    </div>

    <div class="px-4 pb-16 md:px-8" style="max-width: 640px; padding-top: 8px;">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <%# ── Profile ── %>
        <div class="v2-card" style="padding: 0; margin-bottom: 16px;">
          <div style="padding: 10px 18px 6px;"><span class="v2-section-label">Profile</span></div>
          <div style="padding: 0 18px 18px;">
            <div style="margin-bottom: 14px;">
              <label style="display: block; margin-bottom: 6px; font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);">First Name</label>
              <%= f.text_field :first_name, autocomplete: "given-name", placeholder: "Your first name",
                  style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
            </div>
            <div style="margin-bottom: 14px;">
              <label style="display: block; margin-bottom: 6px; font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);">Email</label>
              <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com",
                  style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
              <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
                <div style="margin-top: 8px; padding: 8px 12px; border-radius: 6px; background: var(--hover-tint); font-family: var(--font-body); font-size: 0.8rem; color: var(--ink-secondary);">
                  Waiting confirmation for: <%= resource.unconfirmed_email %>
                </div>
              <% end %>
            </div>
            <div>
              <label style="display: block; margin-bottom: 6px; font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);">Time Zone</label>
              <%= f.select :timezone,
                  ActiveSupport::TimeZone.us_zones.map { |tz| [tz.to_s, tz.name] },
                  {},
                  style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
            </div>
          </div>
        </div>

        <%# ── Change Password ── %>
        <div class="v2-card" style="padding: 0; margin-bottom: 16px;">
          <div style="padding: 10px 18px 6px;"><span class="v2-section-label">Change Password</span></div>
          <div style="padding: 0 18px 18px;">
            <p class="v2-caption" style="color: var(--ink-faint); margin-bottom: 12px;">Leave blank if you don't want to change it.</p>
            <div style="margin-bottom: 14px;">
              <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                <label style="font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);">New Password</label>
                <% if @minimum_password_length %>
                  <span style="font-family: var(--font-body); font-size: 0.667rem; color: var(--ink-faint);"><%= @minimum_password_length %> characters min</span>
                <% end %>
              </div>
              <%= f.password_field :password, autocomplete: "new-password", placeholder: "Enter new password",
                  style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
            </div>
            <div>
              <label style="display: block; margin-bottom: 6px; font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);">Confirm Password</label>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm new password",
                  style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
            </div>
          </div>
        </div>

        <%# ── Confirm ── %>
        <div class="v2-card" style="padding: 0; margin-bottom: 16px;">
          <div style="padding: 10px 18px 6px;"><span class="v2-section-label">Confirm Changes</span></div>
          <div style="padding: 0 18px 18px;">
            <p class="v2-caption" style="color: var(--ink-faint); margin-bottom: 8px;">Enter your current password to save changes.</p>
            <%= f.password_field :current_password, autocomplete: "current-password", placeholder: "Current password",
                style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
          </div>
        </div>

        <%= f.submit "Update Account", class: "v2-btn v2-btn-primary", style: "width: 100%; padding: 10px; font-size: 0.9rem; justify-content: center; margin-bottom: 24px;" %>
      <% end %>

      <%# ── Danger Zone ── %>
      <div class="v2-card" style="padding: 0;">
        <div style="padding: 10px 18px 6px;"><span class="v2-section-label" style="color: var(--overdue);">Danger Zone</span></div>
        <div style="padding: 0 18px 18px;">
          <p class="v2-caption" style="color: var(--ink-faint); margin-bottom: 12px;">Permanently delete your account and all data. This cannot be undone.</p>
          <%= button_to "Delete My Account", registration_path(resource_name),
              data: { confirm: "Are you sure? This action cannot be undone." },
              method: :delete,
              class: "v2-btn v2-btn-danger" %>
        </div>
      </div>
    </div>
  </main>
</div>
