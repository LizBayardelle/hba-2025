<%= render 'shared/public_nav' %>

<div class="min-h-screen flex items-center justify-center px-4 py-12" style="background: var(--bg);">
  <div class="w-full max-w-sm">
    <!-- Logo -->
    <div class="text-center" style="margin-bottom: 32px;">
      <div style="width: 36px; height: 36px; background: var(--ink); border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 12px;">
        <svg width="18" height="18" viewBox="0 0 14 14" fill="none"><rect x="2" y="3" width="4" height="8" rx="1" fill="var(--bg)"/><rect x="8" y="3" width="4" height="5" rx="1" fill="var(--bg)" opacity="0.5"/></svg>
      </div>
      <h1 class="v2-h2" style="margin-bottom: 4px;">Create your account</h1>
      <p class="v2-small" style="color: var(--ink-tertiary);">Free forever. No credit card needed.</p>
    </div>

    <!-- Card -->
    <div class="v2-card" style="padding: 28px;">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div style="margin-bottom: 16px;">
          <%= f.label :first_name, "First Name", style: "display: block; margin-bottom: 6px; font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);" %>
          <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name", placeholder: "Your first name",
              style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
        </div>

        <div style="margin-bottom: 16px;">
          <%= f.label :email, "Email", style: "display: block; margin-bottom: 6px; font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);" %>
          <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com",
              style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
        </div>

        <div style="margin-bottom: 16px;">
          <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
            <%= f.label :password, "Password", style: "font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);" %>
            <% if @minimum_password_length %>
              <span style="font-family: var(--font-body); font-size: 0.667rem; color: var(--ink-faint);"><%= @minimum_password_length %> characters min</span>
            <% end %>
          </div>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "Choose a password",
              style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
        </div>

        <div style="margin-bottom: 16px;">
          <%= f.label :password_confirmation, "Confirm Password", style: "display: block; margin-bottom: 6px; font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirm your password",
              style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
        </div>

        <div style="margin-bottom: 20px;">
          <%= f.label :timezone, "Time Zone", style: "display: block; margin-bottom: 6px; font-family: var(--font-body); font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary);" %>
          <%= f.select :timezone,
              ActiveSupport::TimeZone.us_zones.map { |tz| [tz.to_s, tz.name] },
              { selected: 'Pacific Time (US & Canada)' },
              style: "width: 100%; padding: 10px 12px; border-radius: 8px; border: 1px solid var(--border); background: var(--surface); color: var(--ink); font-family: var(--font-body); font-size: 0.9rem; outline: none;" %>
        </div>

        <%= f.submit "Create Account", class: "v2-btn v2-btn-primary", style: "width: 100%; padding: 10px; font-size: 0.9rem; justify-content: center;" %>
      <% end %>
    </div>

    <div style="text-align: center; margin-top: 20px;">
      <span style="font-family: var(--font-body); font-size: 0.833rem; color: var(--ink-tertiary);">Already have an account? </span>
      <%= link_to "Sign in", new_session_path(resource_name), style: "font-family: var(--font-body); font-size: 0.833rem; color: var(--ink); font-weight: 500; text-decoration: none;" %>
    </div>
  </div>
</div>
