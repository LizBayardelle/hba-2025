<div class="flex h-screen relative" style="background-color: var(--bg);">
  <%= render 'shared/sidebar' %>

  <main class="flex-1 overflow-y-auto md:ml-[224px]">
    <!-- v2 Header -->
    <div class="sticky top-0 z-10" style="background: var(--bg);">
      <div class="pl-14 pr-4 pt-6 pb-4 md:pl-8 md:pr-8 md:pt-8 md:pb-5">
        <div class="flex items-baseline justify-between">
          <div>
            <h1 class="v2-h1">Projects</h1>
            <p class="v2-small" style="margin-top: 4px; color: var(--ink-tertiary);">
              <%= @projects.count %> active project<%= @projects.count == 1 ? '' : 's' %>
            </p>
          </div>
          <%= button_to projects_path, method: :post, params: { project: { name: "Untitled Project", color: "#9C8B7E", icon: "fa-folder" } }, class: "v2-btn-sm v2-btn-primary" do %>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            New Project
          <% end %>
        </div>
      </div>
      <div style="height: 12px; background: linear-gradient(to bottom, var(--bg), transparent); pointer-events: none;"></div>
    </div>

    <div class="px-4 pb-16 md:px-8" style="max-width: 920px; padding-top: 8px;">
      <% if @projects.any? %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <% @projects.each do |project| %>
            <%
              all_tasks = project.project_tasks.active.top_level
              total_tasks = all_tasks.count
              completed_tasks = all_tasks.where(completed: true).count
              active_tasks = all_tasks.where(completed: false).order(:position).limit(5)
              sections_count = project.sections.active.count
              progress = total_tasks > 0 ? (completed_tasks * 100.0 / total_tasks).round : 0
            %>
            <div class="v2-card" style="padding: 0; overflow: hidden;">
              <%# Color accent bar at top %>
              <div style="height: 4px; background: <%= project.color %>; border-radius: 10px 10px 0 0;"></div>

              <%= link_to project_path(project), style: "text-decoration: none; display: block; padding: 20px 20px 12px;" do %>
                <%# Header: icon + name + stats %>
                <div class="flex items-start gap-3">
                  <div style="width: 32px; height: 32px; border-radius: 7px; background: <%= project.color %>; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                    <i class="fa-solid <%= project.icon %>" style="color: white; font-size: 0.75rem;"></i>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div style="font-family: var(--font-body); font-size: 0.933rem; font-weight: 600; color: var(--ink); line-height: 1.3;"><%= project.name %></div>
                    <div class="flex items-center gap-3" style="margin-top: 2px;">
                      <span class="v2-caption"><%= completed_tasks %>/<%= total_tasks %> tasks</span>
                      <span class="v2-caption"><%= sections_count %> sections</span>
                      <% if total_tasks > 0 %>
                        <span class="v2-caption" style="color: <%= project.color %>;"><%= progress %>%</span>
                      <% end %>
                    </div>
                  </div>
                </div>

                <%# Progress bar %>
                <% if total_tasks > 0 %>
                  <div style="height: 3px; border-radius: 3px; background: var(--border); overflow: hidden; margin-top: 12px;">
                    <div style="height: 100%; width: <%= progress %>%; background: <%= project.color %>; border-radius: 3px;"></div>
                  </div>
                <% end %>
              <% end %>

              <%# Active tasks by section %>
              <%
                sections_with_tasks = project.sections.active.ordered.map { |s|
                  tasks = s.project_tasks.active.top_level.where(completed: false).order(:position).limit(4)
                  [s, tasks]
                }.select { |_, tasks| tasks.any? }
              %>
              <% if sections_with_tasks.any? %>
                <div style="border-top: 1px solid var(--border);">
                  <% sections_with_tasks.each do |section, tasks| %>
                    <div style="padding: 6px 20px 2px; font-family: var(--font-body); font-size: 0.6rem; font-weight: 700; color: var(--ink-faint); letter-spacing: 0.06em; text-transform: uppercase;"><%= section.name %></div>
                    <% tasks.each do |task| %>
                      <div class="flex items-center gap-2.5" style="padding: 5px 20px;">
                        <div style="width: 14px; height: 14px; border-radius: 3px; border: 1.5px solid var(--border-hover); flex-shrink: 0;"></div>
                        <span style="font-family: var(--font-body); font-size: 0.8rem; color: var(--ink); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"><%= task.name %></span>
                        <% if task.due_date %>
                          <span style="font-size: 0.667rem; font-family: var(--font-mono); color: <%= task.due_date < Date.today ? 'var(--overdue)' : 'var(--ink-faint)' %>; white-space: nowrap;"><%= task.due_date.strftime('%b %-d') %></span>
                        <% end %>
                        <% if task.subtasks.active.any? %>
                          <span class="v2-caption" style="color: var(--ink-faint);"><%= task.subtasks.active.where(completed: true).count %>/<%= task.subtasks.active.count %></span>
                        <% end %>
                      </div>
                    <% end %>
                  <% end %>
                  <%
                    shown = sections_with_tasks.sum { |_, tasks| tasks.count }
                    remaining = total_tasks - completed_tasks - shown
                  %>
                  <% if remaining > 0 %>
                    <%= link_to project_path(project), style: "display: block; padding: 6px 20px 8px; font-family: var(--font-body); font-size: 0.733rem; color: var(--ink-faint); text-decoration: none;" do %>
                      + <%= remaining %> more
                    <% end %>
                  <% end %>
                </div>
              <% elsif total_tasks == 0 %>
                <div style="border-top: 1px solid var(--border); padding: 12px 20px;">
                  <span class="v2-caption" style="color: var(--ink-faint);">No tasks yet</span>
                </div>
              <% else %>
                <div style="border-top: 1px solid var(--border); padding: 8px 20px;">
                  <span class="v2-caption" style="color: <%= project.color %>;">All tasks complete</span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="v2-card text-center" style="padding: 48px 24px;">
          <p class="v2-body" style="color: var(--ink);">No projects yet</p>
          <p class="v2-small" style="color: var(--ink-faint); margin-top: 4px;">Create your first project to organize larger work.</p>
          <%= button_to projects_path, method: :post, params: { project: { name: "Untitled Project", color: "#9C8B7E", icon: "fa-folder" } }, class: "v2-btn v2-btn-primary", style: "margin-top: 16px;" do %>
            New Project
          <% end %>
        </div>
      <% end %>
    </div>
  </main>
</div>
