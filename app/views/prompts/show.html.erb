<style>
  .prompt-log-actions { opacity: 0; transition: opacity 0.15s ease; }
  .prompt-grid-row:hover .prompt-log-actions { opacity: 1; }

  .prompt-grid {
    width: auto;
    min-width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-family: var(--font-body);
    font-size: 0.85rem;
  }
  .prompt-grid thead th {
    position: sticky;
    top: 0;
    background: var(--surface);
    text-align: left;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--ink-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
    z-index: 2;
    min-width: 140px;
  }
  .prompt-grid tbody td {
    padding: 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
    color: var(--ink);
    line-height: 1.45;
    min-width: 140px;
  }
  .prompt-grid tbody tr:hover td { background: var(--hover-tint); }
  .prompt-grid .col-when,
  .prompt-grid td.col-when {
    font-weight: 600;
    color: var(--ink);
    white-space: nowrap;
    font-size: 0.78rem;
    min-width: 140px;
    width: 140px;
    position: sticky;
    left: 0;
    background: var(--surface);
    z-index: 1;
  }
  .prompt-grid tbody tr:hover td.col-when { background: var(--hover-tint); }
  .prompt-grid thead th.col-when { z-index: 3; }
  .prompt-grid .col-when .time-sub {
    display: block;
    font-weight: 400;
    color: var(--ink-tertiary);
    font-size: 0.72rem;
  }
  .prompt-grid .col-actions,
  .prompt-grid td.col-actions,
  .prompt-grid th.col-actions {
    width: 1%;
    min-width: 0;
    padding: 8px;
    white-space: nowrap;
  }
  .prompt-grid .cell-long {
    min-width: 240px;
    max-width: 360px;
  }
  .prompt-grid .cell-long .trix-content {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .prompt-grid-scroll {
    overflow-x: auto;
    overflow-y: visible;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
  }
</style>

<div class="flex h-screen relative" style="background-color: var(--bg);">
  <%= render 'shared/sidebar' %>

  <main class="flex-1 overflow-y-auto md:ml-[224px]">
    <% color = @prompt.category&.color || '#8E8E93' %>
    <%
      initial_edit_questions = @questions.map do |q|
        { id: q.id, text: q.text, question_type: q.question_type, options: (q.options.presence || ['']), _destroy: false }
      end
      initial_edit_questions << { id: nil, text: '', question_type: 'short_answer', options: [''], _destroy: false } if initial_edit_questions.empty?
    %>
    <div x-data='{
      "showEditModal": false,
      "editingId": null,
      "editQuestions": <%= initial_edit_questions.to_json %>,
      "editCategoryId": <%= @prompt.category_id.to_s.to_json %>,
      "editTags": <%= @prompt.tag_names.to_json %>,
      "tagInput": "",
      "showTagSuggestions": false,
      "allTags": <%= @available_tags.pluck(:name).to_json %>,
      addTag(name) {
        const trimmed = (name || "").trim();
        if (!trimmed) return;
        if (!this.editTags.some(t => t.toLowerCase() === trimmed.toLowerCase())) {
          this.editTags.push(trimmed);
        }
        this.tagInput = "";
        this.showTagSuggestions = false;
      },
      removeTag(name) {
        this.editTags = this.editTags.filter(t => t !== name);
      },
      filteredTagSuggestions() {
        const q = this.tagInput.toLowerCase();
        return this.allTags.filter(t =>
          t.toLowerCase().includes(q) &&
          !this.editTags.some(s => s.toLowerCase() === t.toLowerCase())
        );
      }
    }'>

      <!-- Header -->
      <div class="sticky top-0 z-10" style="background: var(--bg);">
        <div class="pl-14 pr-4 pt-6 pb-4 md:pl-8 md:pr-8 md:pt-8 md:pb-5">
          <div class="flex items-baseline justify-between">
            <div style="min-width: 0; flex: 1;">
              <%= link_to prompts_path, class: "v2-caption", style: "text-decoration: none; color: var(--ink-tertiary); display: inline-flex; align-items: center; gap: 4px; margin-bottom: 6px;" do %>
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                Prompts
              <% end %>
              <div class="flex items-center gap-3">
                <div style="width: 6px; height: 32px; background: <%= color %>; border-radius: 3px; flex-shrink: 0;"></div>
                <h1 class="v2-h1" style="margin: 0;"><%= @prompt.title %></h1>
              </div>
              <div class="flex items-center gap-3 flex-wrap" style="margin-top: 6px;">
                <span class="v2-small" style="color: var(--ink-tertiary);"><%= @responses.count %> response<%= @responses.count == 1 ? '' : 's' %></span>
                <span class="v2-caption" style="text-transform: uppercase; letter-spacing: 0.04em;"><%= @questions.count %> question<%= @questions.count == 1 ? '' : 's' %></span>
                <% if @prompt.category %>
                  <span class="v2-caption" style="color: <%= color %>;"><%= @prompt.category.name %></span>
                <% end %>
                <% @prompt.tags.each do |tag| %>
                  <span class="v2-caption" style="color: var(--ink-tertiary);">#<%= tag.name %></span>
                <% end %>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <button @click="showEditModal = true" class="v2-btn-sm v2-btn-secondary" title="Edit prompt">
                <i class="fa-solid fa-pen" style="font-size: 0.7rem;"></i>
              </button>
              <% if @prompt.archived? %>
                <%= button_to unarchive_prompt_path(@prompt), method: :patch, class: "v2-btn-sm v2-btn-secondary" do %>
                  Unarchive
                <% end %>
              <% else %>
                <%= button_to archive_prompt_path(@prompt), method: :patch, class: "v2-btn-sm v2-btn-secondary" do %>
                  Archive
                <% end %>
              <% end %>
              <%= button_to prompt_path(@prompt), method: :delete, data: { confirm: "Delete this prompt and all #{@responses.count} responses?" }, class: "v2-btn-sm v2-btn-secondary", style: "color: #C04040;" do %>
                <i class="fa-solid fa-trash" style="font-size: 0.7rem;"></i>
              <% end %>
            </div>
          </div>
        </div>
        <div style="height: 12px; background: linear-gradient(to bottom, var(--bg), transparent); pointer-events: none;"></div>
      </div>

      <!-- Flash -->
      <% if flash[:notice] %>
        <div class="px-4 md:px-8" style="max-width: 760px; margin: 0 auto;">
          <div style="padding: 8px 12px; background: var(--hover-tint); border-radius: 6px; font-size: 0.8rem; color: var(--ink-secondary); margin-bottom: 12px;"><%= flash[:notice] %></div>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="px-4 md:px-8" style="max-width: 760px; margin: 0 auto;">
          <div style="padding: 8px 12px; background: rgba(192,64,64,0.1); border-radius: 6px; font-size: 0.8rem; color: #C04040; margin-bottom: 12px;"><%= flash[:alert] %></div>
        </div>
      <% end %>

      <!-- Log -->
      <div class="px-4 pb-16 md:px-8" style="max-width: 1100px; margin: 0 auto;">
        <% if @prompt.description.present? %>
          <div style="padding: 12px 16px; background: var(--hover-tint); border-radius: 8px; margin-bottom: 20px;">
            <p style="font-family: var(--font-body); font-size: 0.85rem; color: var(--ink-secondary); line-height: 1.5; margin: 0;"><%= simple_format(@prompt.description) %></p>
          </div>
        <% end %>

        <% if @responses.any? && @questions.any? %>
          <% colspan = 2 + @questions.count %>
          <div class="prompt-grid-scroll">
            <table class="prompt-grid">
              <thead>
                <tr>
                  <th class="col-when">When</th>
                  <% @questions.each do |q| %>
                    <th><%= q.text %></th>
                  <% end %>
                  <th class="col-actions"></th>
                </tr>
              </thead>
              <tbody>
                <% @responses.each do |response| %>
                  <tr class="prompt-grid-row">
                    <td class="col-when">
                      <%= response.created_at.in_time_zone(current_user.timezone).strftime('%b %-d, %Y') %>
                      <span class="time-sub"><%= response.created_at.in_time_zone(current_user.timezone).strftime('%-l:%M %p') %></span>
                    </td>
                    <% @questions.each do |q| %>
                      <% a = response.answer_for(q) %>
                      <td class="<%= 'cell-long' if q.question_type == 'long_answer' %>">
                        <% if a.nil? || a.blank_value? %>
                          <span style="color: var(--ink-tertiary);">—</span>
                        <% else %>
                          <% case q.question_type %>
                          <% when "long_answer" %>
                            <div class="trix-content"><%= a.body %></div>
                          <% when "yes_no" %>
                            <span style="display: inline-block; padding: 2px 10px; border-radius: 10px; font-size: 0.72rem; font-weight: 600; background: <%= a.yes_value ? 'rgba(124,179,66,0.15)' : 'rgba(232,121,109,0.12)' %>; color: <%= a.yes_value ? '#3F6B1A' : '#A04030' %>;">
                              <%= a.yes_value ? 'Yes' : 'No' %>
                            </span>
                          <% when "checkboxes" %>
                            <div class="flex flex-wrap gap-1">
                              <% Array(a.selected_value).each do |item| %>
                                <span style="font-size: 0.74rem; padding: 2px 8px; border-radius: 8px; background: var(--hover-tint-strong); color: var(--ink-secondary);"><%= item %></span>
                              <% end %>
                            </div>
                          <% when "integer" %>
                            <span style="font-variant-numeric: tabular-nums; font-weight: 500;"><%= a.number_value %></span>
                          <% else %>
                            <%= a.display_value %>
                          <% end %>
                        <% end %>
                      </td>
                    <% end %>
                    <td class="col-actions">
                      <div class="prompt-log-actions flex items-center gap-1">
                        <button type="button" @click="editingId = (editingId === <%= response.id %> ? null : <%= response.id %>)" class="v2-btn-icon-sm" title="Edit">
                          <i class="fa-solid fa-pen" style="font-size: 0.6rem;"></i>
                        </button>
                        <%= button_to prompt_response_path(response), method: :delete, data: { confirm: "Delete this response?" }, class: "v2-btn-icon-sm", form: { style: "display: inline;" } do %>
                          <i class="fa-solid fa-trash" style="font-size: 0.6rem;"></i>
                        <% end %>
                      </div>
                    </td>
                  </tr>

                  <!-- Inline edit row -->
                  <tr x-show="editingId === <%= response.id %>" x-cloak>
                    <td colspan="<%= colspan %>" style="background: var(--hover-tint); padding: 16px;">
                      <%= form_with model: response, url: prompt_response_path(response), method: :patch, local: true do |f| %>
                        <div class="space-y-3">
                          <% @questions.each do |q| %>
                            <% a = response.answer_for(q) %>
                            <div>
                              <label class="v2-caption" style="display: block; margin-bottom: 4px; color: var(--ink-secondary); font-weight: 600;"><%= q.text %></label>
                              <% case q.question_type %>
                              <% when "short_answer" %>
                                <%= text_field_tag "prompt_response[answers][#{q.id}][text_value]", a&.text_value, class: "form-input", style: "width: 100%; background: var(--surface); font-family: var(--font-body); color: var(--ink); border-color: var(--border);" %>
                              <% when "long_answer" %>
                                <%= text_area_tag "prompt_response[answers][#{q.id}][body]", a&.body&.to_plain_text, rows: 4, class: "form-input", style: "width: 100%; background: var(--surface); font-family: var(--font-body); color: var(--ink); border-color: var(--border);" %>
                              <% when "integer" %>
                                <%= number_field_tag "prompt_response[answers][#{q.id}][number_value]", a&.number_value, step: 1, class: "form-input", style: "width: 100%; background: var(--surface); font-family: var(--font-body); color: var(--ink); border-color: var(--border);" %>
                              <% when "yes_no" %>
                                <div class="flex gap-4" style="font-family: var(--font-body); font-size: 0.9rem;">
                                  <label class="flex items-center gap-2"><input type="radio" name="prompt_response[answers][<%= q.id %>][yes_value]" value="true" <%= 'checked' if a&.yes_value == true %>> Yes</label>
                                  <label class="flex items-center gap-2"><input type="radio" name="prompt_response[answers][<%= q.id %>][yes_value]" value="false" <%= 'checked' if a&.yes_value == false %>> No</label>
                                </div>
                              <% when "multiple_choice" %>
                                <div class="space-y-1" style="font-family: var(--font-body); font-size: 0.9rem;">
                                  <% Array(q.options).each do |opt| %>
                                    <label class="flex items-center gap-2"><input type="radio" name="prompt_response[answers][<%= q.id %>][selected_value]" value="<%= opt %>" <%= 'checked' if a&.selected_value == opt %>> <%= opt %></label>
                                  <% end %>
                                </div>
                              <% when "checkboxes" %>
                                <div class="space-y-1" style="font-family: var(--font-body); font-size: 0.9rem;">
                                  <% Array(q.options).each do |opt| %>
                                    <label class="flex items-center gap-2"><input type="checkbox" name="prompt_response[answers][<%= q.id %>][selected_value][]" value="<%= opt %>" <%= 'checked' if Array(a&.selected_value).include?(opt) %>> <%= opt %></label>
                                  <% end %>
                                </div>
                              <% end %>
                            </div>
                          <% end %>
                        </div>
                        <div class="flex justify-end gap-2" style="margin-top: 12px;">
                          <button type="button" @click="editingId = null" class="v2-btn v2-btn-secondary">Cancel</button>
                          <%= f.submit "Save", class: "v2-btn v2-btn-primary" %>
                        </div>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% elsif @questions.empty? %>
          <div class="v2-small" style="text-align: center; padding: 40px; color: var(--ink-tertiary);">
            No questions yet — add one from the edit modal to start logging answers.
          </div>
        <% else %>
          <div class="v2-small" style="text-align: center; padding: 40px; color: var(--ink-tertiary);">
            No responses yet. Answer this prompt from the <%= link_to "Prompts page", prompts_path, style: "color: var(--ink-secondary); text-decoration: underline;" %>.
          </div>
        <% end %>
      </div>

      <!-- Edit Prompt Modal -->
      <template x-teleport="body">
        <div x-show="showEditModal" @click.self="showEditModal = false" @keydown.escape.window="showEditModal = false" class="fixed inset-0 flex items-center justify-center z-50 p-4" style="background: rgba(0,0,0,0.4); display: none;">
          <div @click.stop class="v2-card" style="padding: 24px; width: 100%; max-width: 36rem; max-height: 90vh; overflow-y: auto;">
            <h2 class="v2-h2" style="margin-bottom: 20px;">Edit Prompt</h2>

            <%= form_with model: @prompt, url: prompt_path(@prompt), method: :patch, local: true do |f| %>
              <div style="margin-bottom: 12px;">
                <label class="v2-caption" style="display: block; margin-bottom: 4px;">Title</label>
                <%= f.text_field :title, required: true, class: "form-input", style: "font-family: var(--font-body); background: var(--surface); color: var(--ink); border-color: var(--border);" %>
              </div>

              <div style="margin-bottom: 12px;">
                <label class="v2-caption" style="display: block; margin-bottom: 4px;">Description</label>
                <%= f.text_area :description, rows: 2, class: "form-input", style: "font-family: var(--font-body); resize: none; background: var(--surface); color: var(--ink); border-color: var(--border);" %>
              </div>

              <%= render 'questions_editor', questions_state: 'editQuestions' %>

              <%= render 'category_tag_pickers',
                    categories: @available_categories,
                    all_tag_names: @available_tags.pluck(:name),
                    category_state: 'editCategoryId',
                    tags_state: 'editTags',
                    tag_input_state: 'tagInput',
                    suggestions_state: 'showTagSuggestions',
                    category_field: 'prompt[category_id]',
                    tags_field: 'prompt[tag_names]' %>

              <div class="flex gap-2 justify-end">
                <button type="button" @click="showEditModal = false" class="v2-btn v2-btn-secondary">Cancel</button>
                <%= f.submit "Save Changes", class: "v2-btn v2-btn-primary" %>
              </div>
            <% end %>
          </div>
        </div>
      </template>
    </div>
  </main>
</div>
