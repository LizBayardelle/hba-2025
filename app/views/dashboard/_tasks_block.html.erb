<div class="v2-card" style="padding: 0;">
  <div class="v2-section-header" style="padding: 14px 18px 10px;">
    <h2 class="v2-section-title">Tasks</h2>
    <div class="flex items-center gap-2">
      <div class="v2-seg-control">
        <button id="tasks-date-btn" onclick="switchTasksView('date')" class="v2-seg-btn active">Date</button>
        <button id="tasks-category-btn" onclick="switchTasksView('category')" class="v2-seg-btn">Category</button>
        <button id="tasks-priority-btn" onclick="switchTasksView('priority')" class="v2-seg-btn">Priority</button>
      </div>
      <button onclick="window.openNewTaskModal()" class="v2-btn-icon-sm" title="New Task">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
    </div>
  </div>

  <div id="tasks-container">
    <%
      all_tasks_with_groups = @tasks.map do |task|
        date_group = if task.due_date.nil?
          'no_date'
        elsif task.due_date < @today
          'overdue'
        elsif task.due_date == @today
          'today'
        else
          'future'
        end

        category_group = task.category_id ? "category_#{task.category_id}" : 'none'
        priority_group = task.importance_level_id ? "level_#{task.importance_level_id}" : 'none'

        {
          task: task,
          date_group: date_group,
          category_group: category_group,
          category_name: task.category&.name || 'No Category',
          category_color: task.category&.color || '#9CA3A8',
          category_icon: task.category&.icon || 'fa-circle',
          priority_group: priority_group,
          priority_name: task.importance_level&.name || 'No Priority',
          priority_rank: task.importance_level&.rank || 999,
          priority_color: task.importance_level&.color || '#657b84',
          priority_icon: task.importance_level&.icon || 'fa-circle'
        }
      end

      date_order = {'overdue' => 0, 'today' => 1, 'no_date' => 2, 'future' => 3}
      all_tasks_with_groups.sort_by! { |t| [date_order[t[:date_group]] || 999, t[:task].due_date || Date.new(9999)] }
    %>

    <% all_tasks_with_groups.each do |task_data| %>
      <% task = task_data[:task] %>
      <div class="task-item flex items-center gap-2.5"
           style="transition: background 0.1s ease; cursor: pointer;"
           data-task-id="<%= task.id %>"
           data-completed="<%= task.completed %>"
           data-date-group="<%= task_data[:date_group] %>"
           data-category-group="<%= task_data[:category_group] %>"
           data-category-name="<%= task_data[:category_name] %>"
           data-category-color="<%= task_data[:category_color] %>"
           data-category-icon="<%= task_data[:category_icon] %>"
           data-priority-group="<%= task_data[:priority_group] %>"
           data-priority-name="<%= task_data[:priority_name] %>"
           data-priority-rank="<%= task_data[:priority_rank] %>"
           data-priority-color="<%= task_data[:priority_color] %>"
           data-priority-icon="<%= task_data[:priority_icon] %>"
           data-due-date="<%= task.due_date&.strftime('%b %d') || '' %>">
        <%# Square checkbox %>
        <button
          onclick="toggleTask(<%= task.id %>, <%= task.completed ? 'true' : 'false' %>)"
          class="flex-shrink-0 cursor-pointer"
          style="width: 18px; height: 18px; border-radius: 4px; display: flex; align-items: center; justify-content: center; border: 1.5px solid <%= task.completed ? 'var(--ink)' : 'var(--border-hover)' %>; background: <%= task.completed ? 'var(--ink)' : 'transparent' %>; transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1); position: relative; overflow: visible;">
          <i class="fa-solid fa-check" style="font-size: 0.55rem; color: var(--check-ink); <%= task.completed ? '' : 'opacity: 0;' %>"></i>
        </button>

        <%# Name + attachments %>
        <div class="flex-1 flex items-center gap-2 min-w-0">
          <span class="<%= task.completed ? 'line-through' : '' %>" style="font-family: var(--font-body); font-size: 0.9rem; color: <%= task.completed ? 'var(--ink-tertiary)' : 'var(--ink)' %>; <%= task.completed ? 'text-decoration-color: var(--ink-faint);' : '' %>">
            <%= task.name %>
          </span>
          <% task.list_attachments.each do |la| %>
            <button onclick="event.stopPropagation(); window.openListShowModal(<%= la.list_id %>)"
                    style="color: var(--ink-faint); font-size: 0.7rem; cursor: pointer; background: none; border: none;"
                    title="<%= la.list.name %>">
              <i class="fa-solid fa-list-check"></i>
            </button>
          <% end %>
        </div>

        <%# Due date %>
        <% if task.due_date %>
          <% if task_data[:date_group] == 'overdue' %>
            <span style="font-size: 0.733rem; font-weight: 500; color: var(--overdue); background: var(--overdue-bg); padding: 1px 7px; border-radius: 8px; white-space: nowrap;"><%= task.due_date.strftime('%b %-d') %></span>
          <% elsif task_data[:date_group] == 'today' %>
            <span style="font-size: 0.733rem; font-weight: 600; color: var(--ink); white-space: nowrap;">Today</span>
          <% else %>
            <span style="font-size: 0.733rem; font-weight: 500; color: var(--ink-tertiary); white-space: nowrap;"><%= task.due_date.strftime('%b %-d') %></span>
          <% end %>
        <% else %>
          <span style="font-size: 0.733rem; color: var(--ink-faint); white-space: nowrap;">No date</span>
        <% end %>
      </div>
    <% end %>

    <% if @tasks.empty? %>
      <div style="text-align: center; padding: 32px 18px;">
        <p class="v2-small" style="color: var(--ink-faint);">No tasks yet</p>
        <button onclick="window.openNewTaskModal()" class="v2-btn v2-btn-primary" style="margin-top: 12px;">New Task</button>
      </div>
    <% end %>
  </div>
</div>
