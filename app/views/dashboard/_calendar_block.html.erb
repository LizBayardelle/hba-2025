<% if current_user.google_sync_enabled && current_user.google_calendar_id.present? %>
  <div class="v2-card" style="padding: 0;">
    <div class="v2-section-header" style="padding: 14px 18px 10px;">
      <h2 class="v2-section-title">Calendar</h2>
      <%= link_to "https://calendar.google.com", target: "_blank", rel: "noopener noreferrer",
          class: "v2-caption", style: "color: var(--ink-tertiary);" do %>
        Open Google
      <% end %>
    </div>
    <% if @calendar_events.any? %>
      <div>
        <% @calendar_events.each do |event| %>
          <div class="flex items-center gap-3 transition cal-event-row" style="border-bottom: 1px solid var(--border);">
            <% if event[:all_day] %>
              <span class="v2-mono" style="width: 68px; flex-shrink: 0; color: var(--ink-tertiary); font-size: 0.8rem;">All day</span>
            <% else %>
              <span class="v2-mono" style="width: 68px; flex-shrink: 0; color: var(--ink-tertiary); font-size: 0.8rem;"><%= event[:start_time].strftime('%l:%M %p').strip %></span>
            <% end %>
            <span class="v2-body" style="font-size: 0.867rem;">
              <%= event[:summary] || 'Untitled Event' %>
              <% if current_user.google_calendar_id.length > 1 %>
                <span class="v2-small" style="margin-left: 4px; color: var(--ink-faint);">(<%= event[:calendar_name] %>)</span>
              <% end %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div style="text-align: center; padding: 24px 18px;">
        <p class="v2-small" style="color: var(--ink-faint);">Nothing planned for today.</p>
      </div>
    <% end %>
    <!-- Footer -->
    <div class="flex items-center justify-between" style="padding: 8px 24px; border-top: 1px solid var(--border);">
      <%= form_with url: google_calendar_refresh_path(date: @today.strftime('%Y-%m-%d')), method: :post, local: true, id: "calendar-refresh-form", style: "display: inline; margin: 0;" do %>
        <button type="submit" id="calendar-refresh-btn" class="v2-caption flex items-center gap-1" style="color: var(--ink-faint); background: none; border: none; padding: 0; cursor: pointer;" title="Refresh calendar">
          <i class="fa-solid fa-refresh" style="font-size: 0.65rem;"></i>
          <span>Refresh</span>
        </button>
      <% end %>
      <% if current_user.calendar_events_cached_at %>
        <span class="v2-caption" style="color: var(--ink-faint);">Updated <%= time_ago_in_words(current_user.calendar_events_cached_at) %> ago</span>
      <% end %>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const refreshForm = document.getElementById('calendar-refresh-form');
      if (refreshForm) {
        refreshForm.addEventListener('submit', (e) => {
          const btn = document.getElementById('calendar-refresh-btn');
          const icon = btn.querySelector('i');
          const text = btn.querySelector('span');
          icon.classList.add('fa-spin');
          text.textContent = 'Refreshing...';
          btn.disabled = true;
        });
      }
    });
  </script>
<% end %>
