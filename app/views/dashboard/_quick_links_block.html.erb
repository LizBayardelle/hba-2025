<div class="v2-card" style="padding: 0;">
  <div class="v2-section-header" style="padding: 14px 18px 10px;">
    <h2 class="v2-section-title">Quick Links</h2>
  </div>
  <div>
    <%= link_to analytics_path, class: "flex items-center gap-3 transition v2-sidebar-link", style: "padding: 8px 18px; border-bottom: 1px solid var(--border);" do %>
      <i class="fa-solid fa-chart-column"></i>
      <span>View Analytics</span>
    <% end %>
    <%= link_to root_path, class: "flex items-center gap-3 transition v2-sidebar-link", style: "padding: 8px 18px; border-bottom: 1px solid var(--border);" do %>
      <i class="fa-solid fa-folder"></i>
      <span>Browse Categories</span>
    <% end %>
    <%= link_to tasks_path, class: "flex items-center gap-3 transition v2-sidebar-link", style: "padding: 8px 18px;" do %>
      <i class="fa-solid fa-check"></i>
      <span>All Tasks</span>
    <% end %>
  </div>
</div>
