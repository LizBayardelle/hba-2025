<!-- Public Navigation -->
<nav style="background: var(--bg); border-bottom: 1px solid var(--border);">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-14">
      <%= link_to root_path, class: "flex items-center gap-2.5", style: "text-decoration: none;" do %>
        <%= render 'shared/logo', size: 26 %>
        <span style="font-family: var(--font-body); font-size: 0.9rem; font-weight: 600; color: var(--ink); letter-spacing: -0.02em;">Habit Beaver</span>
      <% end %>

      <div class="flex items-center gap-3">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", dashboard_path, class: "v2-btn-sm v2-btn-primary" %>
        <% else %>
          <%= link_to "Sign In", new_user_session_path, style: "font-family: var(--font-body); font-size: 0.833rem; color: var(--ink-secondary); text-decoration: none; padding: 4px 8px;" %>
          <%= link_to "Get Started", new_user_registration_path, class: "v2-btn-sm v2-btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
