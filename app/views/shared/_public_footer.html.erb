<!-- Public Footer -->
<footer style="border-top: 1px solid var(--border); background: var(--bg);">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-2">
        <div style="width: 18px; height: 18px; background: var(--ink-faint); border-radius: 4px; display: flex; align-items: center; justify-content: center;">
          <svg width="9" height="9" viewBox="0 0 14 14" fill="none">
            <rect x="2" y="3" width="4" height="8" rx="1" fill="var(--bg)"/>
            <rect x="8" y="3" width="4" height="5" rx="1" fill="var(--bg)" opacity="0.5"/>
          </svg>
        </div>
        <span style="font-family: var(--font-body); font-size: 0.767rem; color: var(--ink-faint);">
          &copy; <%= Date.today.year %> Habit Beaver
        </span>
      </div>
      <div class="flex gap-5">
        <%= link_to "Privacy", privacy_path, style: "font-family: var(--font-body); font-size: 0.767rem; color: var(--ink-faint); text-decoration: none;" %>
        <%= link_to "Terms", terms_path, style: "font-family: var(--font-body); font-size: 0.767rem; color: var(--ink-faint); text-decoration: none;" %>
        <a href="mailto:help@linchpinindustries.com" style="font-family: var(--font-body); font-size: 0.767rem; color: var(--ink-faint); text-decoration: none;">Contact</a>
      </div>
    </div>
  </div>
</footer>
