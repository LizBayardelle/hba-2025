<div class="flex h-screen relative" style="background-color: var(--bg);">
  <%= render 'shared/sidebar' %>

  <main class="flex-1 overflow-y-auto md:ml-[224px]">
    <!-- v2 Header -->
    <div class="sticky top-0 z-10" style="background: var(--bg);">
      <div class="pl-14 pr-4 pt-6 pb-4 md:pl-8 md:pr-8 md:pt-8 md:pb-5">
        <h1 class="v2-h1">Analytics</h1>
        <p class="v2-small" style="margin-top: 4px; color: var(--ink-tertiary);">
          <%= @days_active %> days on Habit Beaver
        </p>
      </div>
      <div style="height: 12px; background: linear-gradient(to bottom, var(--bg), transparent); pointer-events: none;"></div>
    </div>

    <div class="px-4 pb-16 md:px-8" style="max-width: 920px; padding-top: 8px;">

      <%# ═══════════════════════════════════════════
          1. HERO STATS — lifetime numbers
          ═══════════════════════════════════════════ %>
      <div class="v2-card" style="padding: 0; margin-bottom: 20px;">
        <div class="grid grid-cols-3 sm:grid-cols-5" style="gap: 1px; background: var(--border); border-radius: 10px; overflow: hidden;">
          <div style="background: var(--surface); padding: 14px 10px; text-align: center;">
            <div style="font-family: var(--font-mono); font-size: 1.2rem; font-weight: 400; color: var(--ink); letter-spacing: -0.02em;"><%= number_with_delimiter(@lifetime_completions) %></div>
            <div class="v2-caption" style="margin-top: 4px;">Completions</div>
          </div>
          <div style="background: var(--surface); padding: 14px 10px; text-align: center;">
            <div style="font-family: var(--font-mono); font-size: 1.2rem; font-weight: 400; color: var(--ink); letter-spacing: -0.02em;"><%= @tasks_completed %></div>
            <div class="v2-caption" style="margin-top: 4px;">Tasks done</div>
          </div>
          <div style="background: var(--surface); padding: 14px 10px; text-align: center;">
            <div style="font-family: var(--font-mono); font-size: 1.2rem; font-weight: 400; color: var(--ink); letter-spacing: -0.02em;"><%= @journal_entries %></div>
            <div class="v2-caption" style="margin-top: 4px;">Journal entries</div>
          </div>
          <div style="background: var(--surface); padding: 14px 10px; text-align: center;">
            <div style="font-family: var(--font-mono); font-size: 1.2rem; font-weight: 400; color: var(--ink); letter-spacing: -0.02em;"><%= @goals_completed %>/<%= @goals_total %></div>
            <div class="v2-caption" style="margin-top: 4px;">Goals</div>
          </div>
          <div style="background: var(--surface); padding: 14px 10px; text-align: center;">
            <div style="font-family: var(--font-mono); font-size: 1.2rem; font-weight: 400; color: var(--ink); letter-spacing: -0.02em;"><%= @days_active %></div>
            <div class="v2-caption" style="margin-top: 4px;">Days active</div>
          </div>
        </div>
      </div>

      <%# ═══════════════════════════════════════════
          2. STREAKS & HEALTH — current state
          ═══════════════════════════════════════════ %>
      <% show_streaks = current_user.analytics_display.in?(%w[both streaks]) %>
      <% show_health = current_user.analytics_display.in?(%w[both health]) %>
      <div class="grid grid-cols-1 <%= 'sm:grid-cols-2' if show_streaks && show_health %> gap-4" style="margin-bottom: 20px;">
        <% if show_streaks %>
        <%# Perfect streak + best streak %>
        <div class="v2-card" style="padding: 20px;">
          <div class="v2-section-label" style="margin-bottom: 12px;">Streaks</div>
          <div style="display: flex; align-items: baseline; gap: 12px; margin-bottom: 16px;">
            <div>
              <div style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 400; color: var(--ink); line-height: 1;"><%= @perfect_streak %></div>
              <div class="v2-caption" style="margin-top: 2px;">Current perfect days</div>
            </div>
            <div style="padding-left: 12px; border-left: 1px solid var(--border);">
              <div style="font-family: var(--font-mono); font-size: 1.1rem; color: var(--ink-secondary);"><%= @best_streak %></div>
              <div class="v2-caption" style="margin-top: 2px;">Best ever</div>
            </div>
          </div>

          <% if @top_streaks.any? { |h| h[:streak] > 0 } %>
            <div style="border-top: 1px solid var(--border); padding-top: 12px;">
              <% @top_streaks.select { |h| h[:streak] > 0 }.each do |h| %>
                <div style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
                  <span style="width: 6px; height: 6px; border-radius: 50%; background: <%= h[:color] %>; flex-shrink: 0;"></span>
                  <span style="font-family: var(--font-body); font-size: 0.833rem; color: var(--ink); flex: 1;"><%= h[:name] %></span>
                  <span style="font-family: var(--font-mono); font-size: 0.767rem; color: <%= h[:color] %>; font-weight: 500;">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" style="display: inline; vertical-align: -1px;"><path d="M12 23c-1.5 0-5-1-7-5.5S3 8 3 8s3.5 2 6 .5S12 3 12 1c0 2 .5 5.5 3 7S21 8 21 8s-1 9-3 13.5S13.5 23 12 23z"/></svg>
                    <%= h[:streak] %>
                  </span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
        <% end %>

        <% if show_health %>
        <%# Overall health %>
        <div class="v2-card" style="padding: 20px;">
          <div class="v2-section-label" style="margin-bottom: 12px;">Health</div>
          <div style="display: flex; align-items: baseline; gap: 8px; margin-bottom: 16px;">
            <div style="font-family: var(--font-display); font-size: 2.5rem; font-weight: 400; color: var(--ink); line-height: 1;"><%= @overall_health %>%</div>
            <div class="v2-caption">average</div>
          </div>

          <%# Health bar %>
          <div style="height: 6px; border-radius: 6px; background: var(--border); overflow: hidden; margin-bottom: 16px;">
            <div style="height: 100%; width: <%= @overall_health %>%; background: var(--ink); border-radius: 6px; transition: width 0.5s ease;"></div>
          </div>

          <% if @at_risk.any? %>
            <div style="border-top: 1px solid var(--border); padding-top: 12px;">
              <div class="v2-caption" style="color: var(--overdue); margin-bottom: 8px;">
                <i class="fa-solid fa-triangle-exclamation" style="font-size: 0.6rem; margin-right: 3px;"></i>
                <%= @at_risk.count %> habit<%= @at_risk.count == 1 ? '' : 's' %> at risk
              </div>
              <% @at_risk.first(3).each do |h| %>
                <div style="display: flex; align-items: center; gap: 8px; padding: 4px 0;">
                  <span style="width: 6px; height: 6px; border-radius: 50%; background: <%= h[:color] %>; flex-shrink: 0;"></span>
                  <span style="font-family: var(--font-body); font-size: 0.833rem; color: var(--ink); flex: 1;"><%= h[:name] %></span>
                  <span style="font-family: var(--font-mono); font-size: 0.733rem; color: var(--overdue);"><%= h[:health] %>%</span>
                </div>
              <% end %>
            </div>
          <% else %>
            <div style="border-top: 1px solid var(--border); padding-top: 12px;">
              <div class="v2-caption" style="color: var(--ink-faint);">All habits healthy</div>
            </div>
          <% end %>
        </div>
        <% end %>
      </div>

      <%# ═══════════════════════════════════════════
          3. HEATMAP — 90-day calendar
          ═══════════════════════════════════════════ %>
      <div class="v2-card" style="padding: 20px; margin-bottom: 20px;">
        <div class="v2-section-label" style="margin-bottom: 12px;">Last 90 days</div>

        <div class="flex flex-wrap" style="gap: 2px;">
          <% @heatmap_data.each do |date, pct| %>
            <%
              opacity = if pct == 0
                '0.08'
              elsif pct < 25
                '0.2'
              elsif pct < 50
                '0.35'
              elsif pct < 75
                '0.55'
              elsif pct < 100
                '0.75'
              else
                '1'
              end
              d = Date.parse(date)
            %>
            <div
              title="<%= d.strftime('%b %-d') %>: <%= pct %>%"
              class="w-2 h-2 sm:w-2.5 sm:h-2.5"
              style="border-radius: 2px; background: var(--ink); opacity: <%= opacity %>;"
            ></div>
          <% end %>
        </div>

        <div style="display: flex; align-items: center; gap: 4px; margin-top: 8px;">
          <span class="v2-caption" style="color: var(--ink-faint);">Less</span>
          <% [0.08, 0.2, 0.35, 0.55, 0.75, 1].each do |op| %>
            <div class="w-2 h-2 sm:w-2.5 sm:h-2.5" style="border-radius: 2px; background: var(--ink); opacity: <%= op %>;"></div>
          <% end %>
          <span class="v2-caption" style="color: var(--ink-faint);">More</span>
        </div>
      </div>

      <%# ═══════════════════════════════════════════
          4. WEEKLY TREND — bar chart
          ═══════════════════════════════════════════ %>
      <div class="v2-card" style="padding: 20px; margin-bottom: 20px;">
        <div class="v2-section-label" style="margin-bottom: 12px;">Weekly trend</div>
        <div style="display: flex; align-items: end; gap: 6px; height: 80px;">
          <% max_pct = [@weekly_trend.map { |w| w[:pct] }.max || 1, 1].max %>
          <% @weekly_trend.each do |week| %>
            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px;">
              <div style="width: 100%; border-radius: 3px 3px 0 0; background: var(--ink); opacity: <%= week[:pct] > 0 ? [0.2 + (week[:pct].to_f / 100 * 0.8), 1].min : 0.06 %>; height: <%= [week[:pct].to_f / max_pct * 64, 3].max %>px; transition: height 0.3s ease;"
                title="<%= week[:label] %>: <%= week[:pct] %>% (<%= week[:perfect_days] %>/<%= week[:total_days] %> days)"></div>
            </div>
          <% end %>
        </div>
        <div style="display: flex; gap: 6px; margin-top: 4px;">
          <% @weekly_trend.each_with_index do |week, i| %>
            <div style="flex: 1; text-align: center;">
              <% if i == 0 || i == @weekly_trend.length - 1 || i == @weekly_trend.length / 2 %>
                <span class="v2-caption" style="font-size: 0.6rem; color: var(--ink-faint);"><%= week[:label] %></span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <%# ═══════════════════════════════════════════
          5. CATEGORY BREAKDOWN
          ═══════════════════════════════════════════ %>
      <% if @category_stats.any? %>
        <div class="v2-card" style="padding: 0; margin-bottom: 20px;">
          <div class="v2-section-header" style="padding: 14px 18px 10px;">
            <h2 class="v2-section-title">By category</h2>
          </div>
          <% @category_stats.each do |cat| %>
            <div style="padding: 12px 24px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
              <span style="width: 8px; height: 8px; border-radius: 50%; background: <%= cat[:color] %>; flex-shrink: 0;"></span>
              <div style="flex: 1; min-width: 0;">
                <div style="font-family: var(--font-body); font-size: 0.9rem; font-weight: 500; color: var(--ink);"><%= cat[:name] %></div>
                <div class="v2-caption" style="color: var(--ink-faint);">
                  <%= cat[:habits_count] %> habit<%= cat[:habits_count] == 1 ? '' : 's' %>
                  <% if cat[:best_streak] > 0 %>
                    &middot; best streak: <%= cat[:best_habit] %> (<%= cat[:best_streak] %>)
                  <% end %>
                </div>
              </div>
              <div style="text-align: right;">
                <div style="font-family: var(--font-mono); font-size: 0.867rem; color: <%= cat[:color] %>;"><%= cat[:avg_health] %>%</div>
                <div class="v2-caption" style="color: var(--ink-faint);">health</div>
              </div>
              <div style="text-align: right;">
                <div style="font-family: var(--font-mono); font-size: 0.867rem; color: var(--ink);"><%= number_with_delimiter(cat[:total_completions]) %></div>
                <div class="v2-caption" style="color: var(--ink-faint);">total</div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# ═══════════════════════════════════════════
          6. THIS WEEK — activity pulse
          ═══════════════════════════════════════════ %>
      <div class="v2-card" style="padding: 20px; margin-bottom: 20px;">
        <div class="v2-section-label" style="margin-bottom: 12px;">This week</div>
        <div class="grid grid-cols-3 sm:grid-cols-5 gap-3">
          <div>
            <div style="font-family: var(--font-mono); font-size: 1.1rem; color: var(--ink);"><%= @this_week[:completions] %></div>
            <div class="v2-caption">Completions</div>
          </div>
          <div>
            <div style="font-family: var(--font-mono); font-size: 1.1rem; color: var(--ink);"><%= @this_week[:tasks_done] %></div>
            <div class="v2-caption">Tasks done</div>
          </div>
          <div>
            <div style="font-family: var(--font-mono); font-size: 1.1rem; color: var(--ink);"><%= @this_week[:journal_entries] %></div>
            <div class="v2-caption">Journal</div>
          </div>
          <div>
            <div style="font-family: var(--font-mono); font-size: 1.1rem; color: var(--ink);"><%= @this_week[:notes_created] %></div>
            <div class="v2-caption">Notes</div>
          </div>
          <div>
            <div style="font-family: var(--font-mono); font-size: 1.1rem; color: var(--ink);"><%= @this_week[:prep_answered] %></div>
            <div class="v2-caption">Prep answers</div>
          </div>
        </div>
      </div>

    </div>
  </main>
</div>
